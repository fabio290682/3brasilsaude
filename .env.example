# MONGO_URI: Connection string for MongoDB.
# Example: mongodb://127.0.0.1:27017/bloodbank
MONGO_URI="mongodb://127.0.0.1:27017/bloodbank"

# PORT: Optional backend port for the server.
PORT=4000

# API_KEY: Optional key for API access control.
API_KEY=changeme

# ENCRYPTION_KEY: base64-encoded 32-byte key for field encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-with-base64-key

# CORS_ORIGIN: Allowed frontend origin for production.
CORS_ORIGIN=http://localhost:4200

# NODE_ENV: production or development.
NODE_ENV=production

# MongoDB pool tuning for production.
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=5

# Rate limit window and max requests per client.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
